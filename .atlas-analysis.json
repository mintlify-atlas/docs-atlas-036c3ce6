  "keyFeatures": [
    "RESTful API for property management (CRUD operations)",
    "OpenAPI/Swagger documentation with interactive UI",
    "Basic authentication for admin operations",
    "Automatic unique ID generation for properties",
    "Zod schema validation for type safety",
    "Cloudflare Workers serverless deployment",
    "Cloudflare D1 SQLite database",
    "Property status tracking (Available, Reserved, Rented, Sold)",
    "Support for rental and sale property types"
  ],
  "publicApiSurface": [
    "GET /api/propiedades - List all properties",
    "GET /api/propiedades/{id} - Get property by ID",
    "POST /api/propiedades - Create new property (requires auth)",
    "PATCH /api/propiedades/{id} - Update property (requires auth)",
    "DELETE /api/propiedades/{id} - Delete property (requires auth)",
    "GET /api/auth/verify - Verify admin credentials",
    "GET /doc - OpenAPI JSON specification",
    "GET /ui - Swagger UI interface"
  ]
